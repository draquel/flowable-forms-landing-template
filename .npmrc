# Route the @flowable scope to Flowable's JFrog Artifactory npm registry.
# All other (public) packages resolve from the default npmjs registry — the
# flowable-npm-all repo does not proxy public npm.
# Credentials are NOT stored here — keep the auth token in your user-level
# ~/.npmrc so it is never committed to a repo clone.
# See README.md ("Registry authentication") for setup.
@flowable:registry=https://repo.flowable.com/artifactory/api/npm/flowable-npm-all/
always-auth=true
