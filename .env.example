# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values for your environment.
# `.env` is git-ignored. Only VITE_-prefixed vars are exposed to the browser.
# ---------------------------------------------------------------------------

# Base URL of the Flowable backend that serves form definitions.
# Local dev example:
VITE_FLOWABLE_API_URL=http://localhost:8090

# When true, the client calls the Vite dev proxy ("/flowable-api") instead of
# VITE_FLOWABLE_API_URL directly. Use this in local dev to avoid CORS.
# Set to false (or remove) in builds that hit the backend directly.
VITE_USE_DEV_PROXY=true

# Key/identifier of the form to render on the landing page.
VITE_FLOWABLE_FORM_KEY=myFormKey

# Auth token sent as `Authorization: Bearer <token>` on form requests.
# Leave blank if the endpoint is public or auth is handled by a session cookie.
VITE_FLOWABLE_API_TOKEN=

# Optional: REST path that looks up form definition(s) by key.
# `{key}` is replaced with VITE_FLOWABLE_FORM_KEY. On Flowable Work this returns
# a paged list (one entry per version); the client then fetches the model below.
VITE_FLOWABLE_FORM_PATH=/form-api/form-repository/form-definitions?key={key}

# Optional: REST path that returns the form *model* ({ rows: [...] }) for a
# definition id. `{id}` is replaced with the latest version's id from the lookup.
VITE_FLOWABLE_FORM_MODEL_PATH=/form-api/form-repository/form-definitions/{id}/model

# ---------------------------------------------------------------------------
# Start-instance flow (StartInstancePage, route "/") — the PRIMARY use case.
# On submit, start a new process/case from the form values.
# ---------------------------------------------------------------------------

# What a submit starts: "process" (BPMN) or "case" (CMMN).
VITE_FLOWABLE_START_KIND=process

# Definition key of the process/case to start.
VITE_FLOWABLE_DEFINITION_KEY=myProcessOrCaseKey

# Optional: override the start endpoint. If blank, a default is used based on
# VITE_FLOWABLE_START_KIND:
#   process -> /process-api/runtime/process-instances
#   case    -> /cmmn-api/cmmn-runtime/case-instances
VITE_FLOWABLE_START_PATH=

# ---------------------------------------------------------------------------
# Complete-task flow (TaskFormPage, route "/task?taskId=...") — second example.
# Form-fetch path is verified; the complete path/body may need adjusting.
# ---------------------------------------------------------------------------

# REST path returning a task's form model. `{taskId}` is substituted.
VITE_FLOWABLE_TASK_FORM_PATH=/platform-api/tasks/{taskId}/form

# REST path returning a task's existing variable values (to pre-fill the form,
# e.g. read-only fields from the start form). `{taskId}` is substituted.
VITE_FLOWABLE_TASK_VALUES_PATH=/platform-api/tasks/{taskId}/variables

# REST path to complete a task. `{taskId}` is substituted.
VITE_FLOWABLE_TASK_COMPLETE_PATH=/platform-api/tasks/{taskId}/complete
